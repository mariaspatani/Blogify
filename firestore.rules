rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone can read; only the owning user can write
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // Comments — anyone can read; only authenticated users can create;
    // only the comment author can delete
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Likes — anyone can read; authenticated users manage their own
    match /likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.resource == null || request.resource.data.uid == request.auth.uid);
    }

    // Bookmarks — authenticated users manage their own only
    match /bookmarks/{bookmarkId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if request.auth != null
        && (request.resource == null || request.resource.data.uid == request.auth.uid);
    }
  }
}
